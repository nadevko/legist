use flake ..
git config core.hooksPath git

. .env

export PUBLIC_HOST="legist.nadevko.cc"
export BASE_PATH="/api"
export ADDR=:8080
export ENV=dev
export DATA_PATH=../data

export QDRANT_HOST=127.0.0.1
export QDRANT_GRPC_PORT=6334

export OLLAMA_BASE_URL=http://127.0.0.1:11434
export EMBED_MODEL=nomic-embed-text
export EMBED_BATCH_SIZE=32
export EMBED_USE_WEIGHT_PREFIX=1
export EMBED_SHORT_CHUNK_PREFIX_MAX_CHARS=200
export EMBED_PROGRESS_INTERVAL_MS=500
export EMBED_HTTP_TIMEOUT_MS=120000
export WEIGHT_CRITICAL=3.0
export WEIGHT_MAIN=2.0
export WEIGHT_STANDARD=1.0
export WEIGHT_TECHNICAL=0.5
export WEIGHT_MAX_CAP=3.0
# Weight classification rules for embedding + weighted similarity (JSON seed array).
export WEIGHT_REGEX_FILE=$PWD/internal/config/weights-seed.json
export DIFF_MATCH_THRESHOLD_LOW=0.4
export DIFF_MATCH_THRESHOLD_HIGH=0.85
# `regex/omits` seed JSON (JSON seed array). Used as omit regex list for pre-embedding cleaning + skip.
export DIFF_MATCH_REGEX_FILE=$PWD/internal/config/omits-seed.json
export METADATA_MODEL=qwen2.5:3b
export METADATA_LLM_HTTP_TIMEOUT_MS=60000
# Optional: path to UTF-8 prompt file (instructions + trailing newline before document fragment). Omit = bundled default.
# export METADATA_LLM_PROMPT_FILE=$PWD/internal/config/metadata_prompt_default.txt

export LLM_METADATA=ollama
export LLM_ANALYSIS=ollama

export ANTHROPIC_API_KEY=
export DEEPSEEK_API_KEY=
